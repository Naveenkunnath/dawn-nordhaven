<section class="featured-categories">
  <div class="page-width">
    {% render 'section-header', heading: section.settings.heading, description: section.settings.description %}
    <div class="featured-categories__grid">
      {% for block in section.blocks %}
        {% render 'category-card', collection: block.settings.collection, block: block %}
      {% endfor %}
    </div>
  </div>
</section>
{% stylesheet %}
  .featured-categories {
    text-align: center;
  }
  .featured-categories__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }
{% endstylesheet %}
{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured Categories"
    }
  ]
}
{% endschema %}
