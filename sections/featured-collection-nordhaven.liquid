<section class="featured-collection">
  <div class="page-width">
    <div class="featured-collection__header">
      {% render 'section-header', heading: section.settings.heading, description: section.settings.description %}
    </div>

    <div class="featured-collection__products">
      {% if section.settings.collection != blank %}
        {% assign collection = section.settings.collection %}
        {% for product in collection.products limit: 4 %}
          {% render 'card-product-nordhaven', product: product, show_price: true, show_vendor: true, show_badge: true %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    padding: 5rem 0;
  }

  .featured-collection__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .featured-collection__heading {
    margin: 0 0 1rem;
  }

  .featured-collection__description {
    margin: 0;
  }
  .featured-collection__products {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
  }

  @media screen and (max-width: 989px) {
    .featured-collection__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .featured-collection__products {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Nordhaven"
    }
  ]
}
{% endschema %}
