<section class="newsletter" style="--bg-color: {{ section.settings.background }}">
  <div class="page-width">
    {% render 'section-header', heading: section.settings.heading, description: section.settings.description %}

    {% form 'customer', class: 'newsletter__form' %}
      <input
        type="hidden"
        name="contact[tags]"
        value="newsletter"
      >

      <input
        type="email"
        name="contact[email]"
        placeholder="Enter your email"
        required
        class="newsletter__input"
      >

      <button
        type="submit"
        class="button button--primary newsletter__button"
      >
        {{ section.settings.button_label }}
      </button>
      {% if form.posted_successfully? %}
        <p class="newsletter__success">Thanks for subscribing!</p>
      {% endif %}

      {% if form.errors %}
        <p class="newsletter__error">
          {{ form.errors | default_errors }}
        </p>
      {% endif %}
    {% endform %}
  </div>
</section>
{% stylesheet %}
  .newsletter {
    padding: 5rem 0;
    text-align: center;
    background-color: var(--bg-color);
  }

  .newsletter__form {
    max-width: 600px;
    margin: 2rem auto 0;

    display: flex;
    gap: 1rem;
  }

  .newsletter__input {
    flex: 1;
    padding: 1rem;
  }

  .newsletter__button {
    padding: 1rem 2rem;
  }

  @media screen and (max-width: 749px) {
    .newsletter__form {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "color_background",
      "id": "background",
      "label": "Background",
      "default": "#f6f6f6"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign Up"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "By signing up you agree we will send you marketing updates and accept our Privacy Policy."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Sign Up Our Newsletter"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Nordhaven"
    }
  ]
}
{% endschema %}
