<section class="store-features text-align-center">
  <div class="page-width">
    {% render 'section-header', heading: section.settings.heading, description: section.settings.description %}
    <div class="store-features__grid">
      {% for block in section.blocks %}
        <div class="store-feature position-relative" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="overlay"></a>
          {% endif %}
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 80 }}"
              alt="{{ block.settings.heading | default: 'Feature icon' | escape }}"
              width="80"
              height="80"
            >
          {% endif %}
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% stylesheet %}
  .store-features {
    padding: 4rem 0;
  }

  .store-features__heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .store-features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .store-feature {
    text-align: center;
  }

  .store-feature img {
    display: block;
    margin: 0 auto 1rem;
  }

  .store-feature h3 {
    margin-bottom: 0.75rem;
  }

  .store-feature p {
    margin: 0;
  }
  .position-relative {
    position: relative;
  }
  .overlay {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 1;
    display: block !important;
  }
  .text-align-center {
    text-align: center;
  }
  @media screen and (max-width: 989px) {
    .store-features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .store-features__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Store Features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Section Description"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Feature Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Feature Heading",
          "default": "Free Shipping"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Free shipping on orders over $100."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Feature Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Features",
      "blocks": [{ "type": "feature" }, { "type": "feature" }, { "type": "feature" }]
    }
  ]
}
{% endschema %}
