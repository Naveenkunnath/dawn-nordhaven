{% assign current_variant = product.selected_or_first_available_variant %}
{% assign secondary_image = product.images[1] %}
{% liquid
  if show_price == null
    assign show_price = true
  endif

  if show_vendor == null
    assign show_vendor = false
  endif

  if show_compare_price == null
    assign show_compare_price = true
  endif

  if show_badge == null
    assign show_badge = false
  endif
%}
{% if product != blank %}
  <a href="{{ product.url }}" class="card-product">
    <div class="card-product__image">
      {% if product.featured_image != blank %}
        {{
          product.featured_image
          | image_url: width: 600
          | image_tag: loading: 'lazy', alt: product.featured_image.alt
          | escape
        }}
      {% endif %}
      {% if secondary_image != blank %}
        {{
          secondary_image
          | image_url: width: 600
          | image_tag: loading: 'lazy', alt: secondary_image.featured.alt, class: 'card-product__image-secondary'
          | escape
        }}
      {% endif %}
      {% if show_badge %}
        {% unless current_variant.available %}
          <span class="card-product__badge card-product__badge--sold-out"> Sold Out </span>
        {% else %}
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="card-product__badge card-product__badge--sale"> Sale </span>
          {% endif %}
        {% endunless %}
      {% endif %}
    </div>
    <div class="card-product__content">
      <h3 class="card-product__title">
        {{ product.title }}
      </h3>
      {% if show_vendor %}
        <p class="card-product__vendor">
          {{ product.vendor }}
        </p>
      {% endif %}
      {% if show_price %}
        <div class="card-product__price">
          {% if show_compare_price and current_variant.compare_at_price > current_variant.price %}
            <span class="card-product__price--compare">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="card-product__price--sale">
              {{ current_variant.price | money }}
            </span>
          {% else %}
            <span class="card-product__price--regular">
              {{ current_variant.price | money }}
            </span>
          {% endif %}
        </div>
      {% endif %}
      {% form 'product', product, class: 'card-product__form' %}
        <input
          type="hidden"
          name="id"
          value="{{ current_variant.id }}"
        >

        <input
          type="hidden"
          name="quantity"
          value="1"
        >

        <button
          type="submit"
          class="card-product__add-button"
          {% unless current_variant.available %}
            Disabled
          {% endunless %}
        >
          {% if current_variant.available %}
            Add to Cart
          {% else %}
            Sold Out
          {% endif %}
        </button>
      {% endform %}
    </div>
  </a>
{% endif %}
{% stylesheet %}
  .card-product {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-product:hover {
    transform: translateY(-4px);
  }
  .card-product__image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #f7f7f5;
  }
  .card-product__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-product__image-secondary {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card-product:hover .card-product__image-secondary {
    opacity: 1;
  }
  .card-product__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.35rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .card-product__badge--sale {
    background: #111;
    color: #fff;
  }

  .card-product__badge--sold-out {
    background: #d32f2f;
    color: #fff;
  }
  .card-product__content {
    padding-top: 1rem;
  }

  .card-product__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
  }
  .card-product__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .card-product__price--compare {
    text-decoration: line-through;
    color: #777;
  }

  .card-product__price--sale {
    font-weight: 700;
  }

  .card-product__price--regular {
    font-weight: 700;
  }
  .card-product__form {
    margin-top: 1rem;
  }

  .card-product__add-button {
    width: 100%;
    padding: 0.85rem;
    border: none;
    background: #111;
    color: #fff;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  .card-product__add-button:hover {
    background: #333;
  }
  .card-product__add-button:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }
{% endstylesheet %}
