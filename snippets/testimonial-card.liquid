<div class="testimonial-card" {{ block.shopify_attributes }}>
  {% if block.settings.image != blank %}
    <div class="testimonial-card__image">
      {{
        block.settings.image
        | image_url: width: 120
        | image_tag: class: 'testimonial-card__image-img', loading: 'lazy'
      }}
    </div>
  {% endif %}
  <div class="testimonial-card__rating">
    {% for i in (1..5) %}
      {% if i <= block.settings.rating %}
        ★
      {% else %}
        ☆
      {% endif %}
    {% endfor %}
  </div>
  <p class="testimonial-card__review">
    {{ block.settings.review }}
  </p>

  <h3 class="testimonial-card__name">
    {{ block.settings.name }}
  </h3>

  {% if block.settings.location != blank %}
    <p class="testimonial-card__location">
      {{ block.settings.location }}
    </p>
  {% endif %}
</div>
{% stylesheet %}
  .testimonial-card {
    padding: 2rem;
    background: #f7f7f5;
    border-radius: 12px;
    text-align: center;
  }

  .testimonial-card__review {
    margin: 0 0 1.5rem;
    line-height: 1.7;
  }

  .testimonial-card__name {
    margin: 0;
    font-size: 1.125rem;
  }

  .testimonial-card__location {
    margin-top: 0.25rem;
    color: #6b7280;
  }
  .testimonial-card__image {
    width: 72px;
    height: 72px;

    margin: 0 auto 1.5rem;
  }

  .testimonial-card__image img {
    width: 100%;
    height: 100%;

    display: block;

    object-fit: cover;

    border-radius: 50%;
  }
  .testimonial-card__rating {
    margin-bottom: 1rem;

    font-size: 1.125rem;

    color: #d4a017;

    letter-spacing: 0.15rem;
  }
{% endstylesheet %}
